{% extends base %}

{% block header %}
<style>
    .num {
        float: right;
        margin-top: -10px;
        font-size: 275%;
    }
</style>
{% if me %}
<style>
    .ranking {
        margin-bottom: 0;
    }
    .myrank-card {
        margin-bottom: 0;
    }
</style>
{% endif %}
{% endblock header %}

{% block card %}
<div class="card-body ranking">
    {% for user in users%}
    <span class="h3">{{ loop.index }}. {{ user.nickname }}</span>
    <span class="num">{{ user.data }}</span>
    <br>
    {{ user.info }}
    {% if not loop.last %}
    <hr>
    {% endif %}
    {% endfor %}
</div>
{% if me %}
<div style="background-color: rgba(var(--mdb-primary-rgb), 0.5);" class="card-body myrank-card">
    <span class="h3">{{ me.index }}. {{ me.nickname }}</span>
    <span class="num">{{ me.data }}</span>
    <br>
    {{ me.info }}
</div>
{% endif %}
{% endblock card %}